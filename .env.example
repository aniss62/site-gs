# ─────────────────────────────────────────────────────────────
# .env.example — Copier en .env et remplir les vraies valeurs.
# Ce fichier est commité ; .env ne l'est JAMAIS.
# ─────────────────────────────────────────────────────────────

# SMTP — Formulaire de contact
# Port 587 = STARTTLS  |  Port 465 = SSL/SMTPS
SMTP_HOST=mail.votre-hebergeur.ma
SMTP_PORT=587
SMTP_USER=Office@lesgreniersdusaiss.ma
SMTP_PASS=
SMTP_FROM=Office@lesgreniersdusaiss.ma
SMTP_TO=Office@lesgreniersdusaiss.ma

# Token d'accès manuel à fetch-news.php (?token=...)
# Choisir une chaîne aléatoire longue en production.
FETCH_NEWS_TOKEN=

# Optionnel — NewsAPI
# NEWS_API_KEY=
